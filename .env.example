APP_NAME="Electricity Planning Engine"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=electricity_planning
DB_USERNAME=postgres
DB_PASSWORD=postgres

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Electricity Planning Engine -------------------------------------------
# Active price provider: "mock" (default, no external calls) or "entsoe".
ENERGY_PRICE_PROVIDER=mock
ENERGY_DEFAULT_ZONE=FR
ENERGY_PRICE_CACHE_TTL=3600

# ENTSO-E Transparency Platform (only used when ENERGY_PRICE_PROVIDER=entsoe).
# Request a free token at https://transparency.entsoe.eu/ under "My Account Settings".
ENTSOE_API_BASE_URL=https://web-api.tp.entsoe.eu/api
ENTSOE_API_TOKEN=

# Default battery / PV / consumption assumptions used when a simulation
# request omits them (see config/energy.php for the full parameter set).
ENERGY_BATTERY_CAPACITY_KWH=10
ENERGY_BATTERY_MAX_POWER_KW=5
ENERGY_BATTERY_ROUND_TRIP_EFFICIENCY=0.90
ENERGY_BATTERY_SOC_MIN_PERCENT=10
ENERGY_BATTERY_SOC_MAX_PERCENT=100
ENERGY_PV_PEAK_POWER_KWC=6
ENERGY_CONSUMPTION_DAILY_BASELINE_KWH=15
ENERGY_MAX_EXPORT_POWER_KW=3
ENERGY_PV_FORECAST_SAFETY_MARGIN=0.0
ENERGY_CONSUMPTION_FORECAST_SAFETY_MARGIN=0.0

# Home Assistant export (bonus integration, optional).
HOME_ASSISTANT_WEBHOOK_URL=
HOME_ASSISTANT_LONG_LIVED_TOKEN=
